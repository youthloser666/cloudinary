datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Photo {
  id          String   @id @default(uuid())
  username    String
  originalUrl String
  finalUrl    String
  filterName  String
  createdAt   DateTime @default(now())
}
